#! /bin/sh

. ${tstdir-.}/lib.sh
. ${tstdir-.}/conf.sh

# Don't test when the client (sender) is regular rsync.
[ $CLIENT_RSYNC = "1" ] && { echo "ignoring client rsync" ; exit 0 ; }

rm -rf dir1 dir2 dir3
# make the copy-from-here tree
mkdir dir1
cd dir1
seq -f%015g 2560 > foo
# make the tree we want to compare to
mkdir ../dir2
cd ../dir2
seq -f%015g 2560 > foo

cd ..
before=$(date +%s)
$rsync --bwlimit=10 -a -- dir1/ dir3
after=$(date +%s)
elapsed=$((after - before))
if [ "$elapsed" -lt 3 ] ; then
    echo too fast: $elapsed 1>&2
    exit 1
fi
if [ "$elapsed" -gt 5 ] ; then
    echo too slow: $elapsed 1>&2
    exit 1
fi
compare_trees dir2 dir3
